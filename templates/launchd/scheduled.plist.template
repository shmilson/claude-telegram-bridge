<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>__LABEL__</string>

  <!-- Runs tg-scheduled.sh with a fixed task prompt at a fixed time. -->
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-l</string>
    <string>__REPO__/tools/tg-bridge/tg-scheduled.sh</string>
    <string>__PROMPT__</string>
  </array>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key><integer>__HOUR__</integer>
    <key>Minute</key><integer>__MINUTE__</integer>
  </dict>

  <key>StandardOutPath</key>
  <string>__REPO__/.tg-bridge/logs/sched.out.log</string>
  <key>StandardErrorPath</key>
  <string>__REPO__/.tg-bridge/logs/sched.err.log</string>
</dict>
</plist>
